{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specflow.local/schemas/workflow-definition.schema.json",
  "title": "Specflow Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "nodes", "edges"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entryNodeId": {
      "type": "string",
      "minLength": 1
    },
    "sessionGroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sessionGroup"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "agentCli": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli", "args"],
      "properties": {
        "cli": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["managedNodeIds", "decisionKinds"],
      "properties": {
        "managedNodeIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "decisionKinds": {
          "type": "array",
          "items": {
            "enum": ["session", "routing", "review", "verification"]
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["control_flow", "data_flow", "review_loop", "control_scope"]
        },
        "label": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "label", "status"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "ticket",
            "spec_context",
            "interview",
            "plan",
            "code_draft",
            "workflow_director",
            "implementation_reviewer",
            "repair",
            "final_patch",
            "visual_decomposer",
            "visual_verifier"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "pending",
            "ready",
            "running",
            "blocked",
            "reviewing",
            "failed",
            "completed"
          ]
        },
        "description": {
          "type": "string"
        },
        "role": {
          "enum": [
            "input",
            "context",
            "worker",
            "reviewer",
            "verifier",
            "director",
            "output"
          ]
        },
        "agentCli": {
          "$ref": "#/$defs/agentCli"
        },
        "session": {
          "$ref": "#/$defs/sessionPolicy"
        },
        "control": {
          "$ref": "#/$defs/control"
        }
      }
    },
    "sessionGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "controllerNodeId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sessionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["none", "shared", "fresh", "ai_decides"]
        },
        "groupId": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "controllerNodeId": {
          "type": "string",
          "minLength": 1
        },
        "newSessionOnLoop": {
          "type": "boolean"
        }
      }
    }
  }
}
